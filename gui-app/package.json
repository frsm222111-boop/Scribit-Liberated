{
  "name": "unbrickit",
  "version": "1.0.0",
  "description": "Control app for ScribIt wall drawing robot",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "unbrickit",
    "wall",
    "drawing",
    "robot",
    "firmware",
    "gcode",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/karimi/scrubit.git"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "electron-store": "^11.0.2",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "build": {
    "appId": "com.unbrickit.app",
    "productName": "UnBrickIt",
    "publish": null,
    "afterPack": "./scripts/sign-mac.js",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "extraResources": [
      {
        "from": "resources/python",
        "to": "python"
      },
      {
        "from": "resources/firmware",
        "to": "firmware"
      },
      {
        "from": "resources/scripts",
        "to": "scripts"
      }
    ]
  }
}
