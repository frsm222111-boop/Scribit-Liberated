{
  "name": "scribit-control",
  "version": "1.0.0",
  "description": "GUI tool for Scribit firmware upload and G-code control",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": ["scribit", "firmware", "gcode", "electron"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "build": {
    "appId": "com.scribit.control",
    "productName": "Scribit Control",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"],
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.ico"
    },
    "extraResources": [
      {
        "from": "resources/python",
        "to": "python"
      },
      {
        "from": "resources/firmware",
        "to": "firmware"
      },
      {
        "from": "resources/scripts",
        "to": "scripts"
      }
    ]
  }
}
